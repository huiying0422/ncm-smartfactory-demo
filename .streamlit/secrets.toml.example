# Streamlit secrets template.
#
# Copy this file to `.streamlit/secrets.toml` (which is git-ignored) and fill in
# your real connection string, OR set the PGURL environment variable / .env file.
#
# On Streamlit Community Cloud, paste this key into:
#   App settings -> Secrets
#
# Format: a standard PostgreSQL connection URL.

PGURL = "postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
